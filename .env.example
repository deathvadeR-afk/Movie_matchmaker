# TMDB API Configuration
VITE_TMDB_API_KEY=your-tmdb-api-key

# Gemini AI Configuration
VITE_GEMINI_API_KEY=your-gemini-api-key
# Optional: Set Gemini model (default: gemini-2.0-flash)
# Options: gemini-2.0-flash, gemini-2.0-pro, gemini-1.5-pro, etc.
VITE_GEMINI_MODEL=gemini-2.0-flash

# Default region for content (e.g., IN, US, GB, JP, KR)
VITE_DEFAULT_REGION=IN

# Redis Cache Server URL (optional - for production caching)
VITE_REDIS_API_URL=http://localhost:3001/api

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
